generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Watchlist {
  id          String   @id @default(cuid())
  name        String
  description String?
  items       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Dashboard {
  id          String   @id @default(cuid())
  name        String
  description String?
  layout      Json
  filters     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SavedCollection {
  id          String   @id @default(cuid())
  name        String
  kind        String
  description String?
  payload     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
