# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Bulk data — build-time only, never deploy
/data/raw/
/data/processed/

# Prisma SQLite DB
prisma/*.db
prisma/*.db-journal

# Codex / dev
.codex-*
.codex-output/
*.log

# Guard against tools persisting an unexpanded Windows home variable in the repository.
/%USERPROFILE%/

# --- Generated & served data (regenerable via the data pipeline; large — keep out of source git) ---
/public/data/
/public/vendor/
/src/data/generated/
/data/

# Large artifacts / screenshots / scratch
*.tar.gz
*.png
New Text Document*.txt

